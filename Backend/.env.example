# ─── Brevo (formerly Sendinblue) ───────────────────────────────────────────
# 1. Sign up free at https://www.brevo.com
# 2. Go to: Account → SMTP & API → API Keys → Generate a new API key
BREVO_API_KEY=your_brevo_api_key_here

# 3. Go to: Senders & IP → Senders → Add a Sender
#    Use any email you own (Gmail works). Brevo will ask you to verify it.
FROM_EMAIL=ayushtiwari2907@gmail.com

# ─── Where contact form emails land ───────────────────────────────────────
TO_EMAIL=ayushtiwari2907@gmail.com

# ─── Server port (Render sets this automatically) ─────────────────────────
PORT=5000
